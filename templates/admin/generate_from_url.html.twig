{% extends '@EasyAdmin/page/content.html.twig' %}

{% block page_title %}Gerar Produto via URL do Mercado Livre{% endblock %}

{% block main %}
<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0">
                    <i class="fa fa-magic me-2 text-primary"></i>
                    Gerar produto automaticamente com IA
                </h5>
            </div>
            <div class="card-body">

                <div class="alert alert-info d-flex gap-2 align-items-start">
                    <i class="fa fa-circle-info mt-1"></i>
                    <div>
                        Cole uma URL de produto do <strong>Mercado Livre</strong>.
                        A IA irá extrair nome, preço, imagem e gerar o review completo com nota automática.
                    </div>
                </div>

                <form method="post" action="{{ action }}">
                    <div class="mb-4">
                        <label for="affiliate_url" class="form-label fw-semibold">
                            URL do produto no Mercado Livre
                        </label>
                        <input
                            type="url"
                            id="affiliate_url"
                            name="affiliate_url"
                            class="form-control form-control-lg"
                            placeholder="https://www.mercadolivre.com.br/..."
                            required
                            autofocus
                        >
                        <div class="form-text text-muted">
                            Exemplo: <code>https://www.mercadolivre.com.br/produto/MLB1234567890</code>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="fa fa-wand-magic-sparkles me-2"></i>
                            Gerar com IA
                        </button>
                        <a href="{{ ea_url().setController('App\\Controller\\Admin\\ProductCrudController').setAction('index') }}"
                           class="btn btn-outline-secondary btn-lg">
                            Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>

        {# Dica de uso #}
        <div class="card border-0 shadow-sm mt-3">
            <div class="card-body">
                <h6 class="fw-semibold mb-2"><i class="fa fa-lightbulb me-2 text-warning"></i>Como funciona</h6>
                <ol class="mb-0 ps-3 text-muted small">
                    <li>Cole a URL do produto no Mercado Livre</li>
                    <li>O sistema busca título, preço e imagem via API</li>
                    <li>A IA Gemini gera veredito, prós, contras, review e <strong>nota (score)</strong></li>
                    <li>O produto é salvo e você pode editar antes de publicar</li>
                </ol>
            </div>
        </div>
    </div>
</div>
{% endblock %}
