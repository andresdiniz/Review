{% extends '@EasyAdmin/layout.html.twig' %}

{% block content_title %}Dashboard{% endblock %}

{% block main %}
<div class="row g-4 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center bg-primary bg-opacity-10" style="width:52px;height:52px;flex-shrink:0">
                    <i class="fas fa-box fa-lg text-primary"></i>
                </div>
                <div>
                    <div class="text-muted small">Total de Produtos</div>
                    <div class="fw-bold fs-4">{{ product_stats.total }}</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center bg-success bg-opacity-10" style="width:52px;height:52px;flex-shrink:0">
                    <i class="fas fa-users fa-lg text-success"></i>
                </div>
                <div>
                    <div class="text-muted small">Usuários</div>
                    <div class="fw-bold fs-4">{{ total_users }}</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center bg-warning bg-opacity-10" style="width:52px;height:52px;flex-shrink:0">
                    <i class="fas fa-star fa-lg text-warning"></i>
                </div>
                <div>
                    <div class="text-muted small">Nota Média</div>
                    <div class="fw-bold fs-4">{{ product_stats.avgScore|number_format(1) }}</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center bg-info bg-opacity-10" style="width:52px;height:52px;flex-shrink:0">
                    <i class="fas fa-tags fa-lg text-info"></i>
                </div>
                <div>
                    <div class="text-muted small">Categorias</div>
                    <div class="fw-bold fs-4">{{ product_stats.categoriesCount }}</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    {# Gráfico de preço médio por categoria #}
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent border-0 pt-3 pb-0">
                <h6 class="mb-0 fw-bold"><i class="fas fa-chart-bar me-2 text-primary"></i>Preço Médio por Categoria</h6>
            </div>
            <div class="card-body">
                <canvas id="chartCategories" height="220"></canvas>
            </div>
        </div>
    </div>
    {# Últimos produtos #}
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent border-0 pt-3 pb-0 d-flex justify-content-between align-items-center">
                <h6 class="mb-0 fw-bold"><i class="fas fa-clock me-2 text-success"></i>Últimos Produtos</h6>
            </div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush">
                    {% for p in latest_products %}
                    <div class="list-group-item border-0 px-3 py-2 d-flex align-items-center gap-3">
                        {% if p.imageUrl %}
                        <img src="{{ p.imageUrl }}" alt="{{ p.name }}" width="40" height="40"
                             style="object-fit:cover;border-radius:8px;flex-shrink:0">
                        {% else %}
                        <div class="d-flex align-items-center justify-content-center bg-light rounded" style="width:40px;height:40px;flex-shrink:0">
                            <i class="fas fa-box text-muted"></i>
                        </div>
                        {% endif %}
                        <div class="flex-grow-1 min-w-0">
                            <div class="fw-semibold text-truncate" style="font-size:.85rem">{{ p.name }}</div>
                            <div class="text-muted" style="font-size:.75rem">R$ {{ p.currentPrice|number_format(2,',','.') }} · {{ p.createdAt ? p.createdAt|date('d/m/Y') : '' }}</div>
                        </div>
                        {% if p.score %}
                        <span class="badge {{ p.score >= 7 ? 'bg-success' : (p.score >= 5 ? 'bg-warning text-dark' : 'bg-danger') }}">
                            {{ p.score }}
                        </span>
                        {% endif %}
                    </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
</div>

{# Alertas #}
{% if product_stats.withoutAi is defined and product_stats.withoutAi > 0 %}
<div class="alert alert-warning d-flex align-items-center gap-2" role="alert">
    <i class="fas fa-robot"></i>
    <div><strong>{{ product_stats.withoutAi }} produto(s)</strong> ainda não têm análise de IA gerada.</div>
</div>
{% endif %}

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    const stats = {{ product_stats|json_encode|raw }};

    // Gráfico de categorias (se o backend fornecer categoryStats)
    const catCtx = document.getElementById('chartCategories');
    if (catCtx && stats.categoryStats) {
        new Chart(catCtx, {
            type: 'bar',
            data: {
                labels: stats.categoryStats.map(c => c.name),
                datasets: [{
                    label: 'Preço Médio (R$)',
                    data: stats.categoryStats.map(c => c.avgPrice),
                    backgroundColor: 'rgba(79,70,229,0.7)',
                    borderRadius: 6,
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: { y: { beginAtZero: true, ticks: { callback: v => 'R$' + v } } }
            }
        });
    } else if (catCtx) {
        catCtx.closest('.card-body').innerHTML = '<p class="text-muted text-center py-4">Adicione <code>categoryStats</code> ao <code>getStats()</code> para ver o gráfico.</p>';
    }
});
</script>
{% endblock %}
