{% extends '@EasyAdmin/page/content.html.twig' %}

{% block page_title %}Redefinir Senha — {{ user.email }}{% endblock %}

{% block main %}
<div class="row justify-content-center">
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0">
                    <i class="fa fa-key me-2 text-warning"></i>
                    Redefinir senha de <strong>{{ user.email }}</strong>
                </h5>
            </div>
            <div class="card-body">
                {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                    <div class="mb-3">
                        {{ form_label(form.password.first) }}
                        {{ form_widget(form.password.first, {'attr': {'class': 'form-control', 'autocomplete': 'new-password'}}) }}
                        {{ form_errors(form.password.first) }}
                    </div>

                    <div class="mb-4">
                        {{ form_label(form.password.second) }}
                        {{ form_widget(form.password.second, {'attr': {'class': 'form-control', 'autocomplete': 'new-password'}}) }}
                        {{ form_errors(form.password.second) }}
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning">
                            <i class="fa fa-save me-1"></i> Salvar nova senha
                        </button>
                        <a href="{{ ea_url().setController('App\\Controller\\Admin\\UserCrudController').setAction('index') }}"
                           class="btn btn-outline-secondary">
                            Cancelar
                        </a>
                    </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
