{% extends 'base.html.twig' %}
{% block title %}Comparar Produtos — ReviewIA{% endblock %}

{% block body %}
<div class="container py-5">
    <h1 style="font-family:'Playfair Display',serif;font-size:2rem;font-weight:900;color:#111827;margin-bottom:.5rem">Comparar Produtos</h1>
    <p class="text-muted mb-4" style="font-family:'DM Sans',sans-serif">Selecione até 3 produtos para comparar lado a lado.</p>

    {# Barra de seleção #}
    <div id="compare-bar" class="d-none position-fixed bottom-0 start-0 end-0 bg-white border-top shadow-lg p-3 d-flex align-items-center justify-content-between" style="z-index:1050">
        <div class="d-flex gap-2 align-items-center">
            <span style="font-family:'DM Sans',sans-serif;font-size:.85rem;font-weight:700">Comparando: </span>
            <span id="compare-count" class="badge bg-primary">0</span>
            <span style="font-family:'DM Sans',sans-serif;font-size:.8rem;color:#6b7280">produto(s) selecionado(s)</span>
        </div>
        <div class="d-flex gap-2">
            <button onclick="clearCompare()" class="btn btn-sm btn-outline-secondary">Limpar</button>
            <button onclick="goCompare()" class="btn btn-sm btn-primary"><i class="fas fa-exchange-alt me-1"></i>Comparar agora</button>
        </div>
    </div>

    {# Resultado da comparação #}
    <div id="compare-result" class="mb-5"></div>

    {# Grid de produtos para seleção #}
    <h2 style="font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:800;margin-bottom:1rem">Escolha os produtos:</h2>
    <div class="row g-3" id="product-grid">
        {% for product in products %}
        <div class="col-md-4 col-sm-6">
            <div class="compare-card p-3 border rounded-3 bg-white h-100"
                 data-slug="{{ product.slug }}"
                 data-name="{{ product.name|e('html_attr') }}"
                 style="cursor:pointer;transition:all .2s;">
                <div class="d-flex gap-3 align-items-start">
                    <div style="flex-shrink:0;width:56px;height:56px;border-radius:10px;overflow:hidden;background:#f5f3ff;display:flex;align-items:center;justify-content:center">
                        {% if product.imageUrl %}
                        <img src="{{ product.imageUrl }}" alt="{{ product.name }}" width="56" height="56" style="object-fit:cover">
                        {% else %}
                        <i class="fas fa-box text-muted"></i>
                        {% endif %}
                    </div>
                    <div class="flex-grow-1">
                        <div class="fw-bold" style="font-size:.9rem;color:#111827;line-height:1.3">{{ product.name }}</div>
                        {% if product.category %}<span class="badge bg-light text-secondary" style="font-size:.65rem">{{ product.category }}</span>{% endif %}
                        <div class="mt-1" style="font-size:.85rem;color:#4f46e5;font-weight:700">R$ {{ product.currentPrice|number_format(2,',','.') }}</div>
                        {% if product.score %}<div style="font-size:.75rem;color:#6b7280">Nota: <strong>{{ product.score }}/10</strong></div>{% endif %}
                    </div>
                    <div class="compare-check" style="width:22px;height:22px;border-radius:50%;border:2px solid #d1d5db;flex-shrink:0;margin-top:2px;display:flex;align-items:center;justify-content:center;transition:all .2s">
                        <i class="fas fa-check" style="font-size:.65rem;color:#fff;display:none"></i>
                    </div>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
</div>

<style>
.compare-card.selected { border-color:#4f46e5 !important; background:#f5f3ff !important; }
.compare-card.selected .compare-check { background:#4f46e5; border-color:#4f46e5; }
.compare-card.selected .compare-check i { display:inline !important; }
.compare-table th { background:#f5f3ff; font-family:'DM Sans',sans-serif; font-size:.8rem; text-align:center; }
.compare-table td { font-family:'DM Sans',sans-serif; font-size:.85rem; vertical-align:middle; }
.compare-table .row-label { font-weight:700; color:#374151; background:#fafafa; white-space:nowrap; }
</style>

<script>
let selected = [];

function updateBar() {
    const bar = document.getElementById('compare-bar');
    document.getElementById('compare-count').textContent = selected.length;
    if (selected.length >= 2) bar.classList.remove('d-none');
    else bar.classList.add('d-none');
}

document.querySelectorAll('.compare-card').forEach(card => {
    card.addEventListener('click', () => {
        const slug = card.dataset.slug;
        if (card.classList.contains('selected')) {
            selected = selected.filter(s => s !== slug);
            card.classList.remove('selected');
        } else {
            if (selected.length >= 3) { alert('Máximo 3 produtos!'); return; }
            selected.push(slug);
            card.classList.add('selected');
        }
        updateBar();
    });
});

function clearCompare() {
    selected = [];
    document.querySelectorAll('.compare-card').forEach(c => c.classList.remove('selected'));
    document.getElementById('compare-result').innerHTML = '';
    updateBar();
}

function goCompare() {
    if (selected.length < 2) return;
    fetch('/api/comparar?slugs=' + selected.join(','))
        .then(r => r.json())
        .then(data => renderTable(data));
}

function stars(score) {
    if (!score) return '—';
    const s = Math.floor(score / 2);
    let h = '';
    for (let i=1;i<=5;i++) h += i<=s ? '★' : '☆';
    return h + ' ' + score + '/10';
}

function renderTable(products) {
    const el = document.getElementById('compare-result');
    let h = `<h2 style="font-family:'Playfair Display',serif;font-weight:900;margin-bottom:1rem;margin-top:2rem">Resultado da Comparação</h2>`;
    h += '<div class="table-responsive"><table class="table compare-table border rounded-3 overflow-hidden">';
    // Header
    h += '<thead><tr><th class="row-label">Critério</th>';
    products.forEach(p => h += `<th><a href="${p.url}" style="color:#4f46e5;font-weight:800">${p.name}</a></th>`);
    h += '</tr></thead><tbody>';
    // Rows
    const rows = [
        ['Preço', p => 'R$ ' + p.currentPrice.toLocaleString('pt-BR', {minimumFractionDigits:2})],
        ['Nota IA', p => stars(p.score)],
        ['Categoria', p => p.category || '—'],
        ['Veredito', p => p.aiVerdict ? p.aiVerdict.substring(0,120)+'…' : '—'],
    ];
    rows.forEach(([label, fn]) => {
        h += `<tr><td class="row-label">${label}</td>`;
        products.forEach(p => h += `<td class="text-center">${fn(p)}</td>`);
        h += '</tr>';
    });
    // Pros
    const maxPros = Math.max(...products.map(p => p.pros.length));
    for (let i=0; i<Math.min(maxPros,3); i++) {
        h += `<tr><td class="row-label">${i===0?'✅ Pros':''}</td>`;
        products.forEach(p => h += `<td style="color:#065f46;font-size:.8rem">${p.pros[i] || ''}</td>`);
        h += '</tr>';
    }
    // Cons
    const maxCons = Math.max(...products.map(p => p.cons.length));
    for (let i=0; i<Math.min(maxCons,3); i++) {
        h += `<tr><td class="row-label">${i===0?'❌ Contras':''}</td>`;
        products.forEach(p => h += `<td style="color:#991b1b;font-size:.8rem">${p.cons[i] || ''}</td>`);
        h += '</tr>';
    }
    h += '</tbody></table></div>';
    el.innerHTML = h;
    el.scrollIntoView({behavior:'smooth'});
}
</script>
{% endblock %}
