{% extends 'base.html.twig' %}

{% block title %}{{ category }} — ReviewIA{% endblock %}
{% block meta_description %}Reviews de produtos na categoria {{ category }}. Avaliações geradas com Inteligência Artificial.{% endblock %}
{% block og_title %}{{ category }} — ReviewIA{% endblock %}
{% block og_description %}Reviews de produtos na categoria {{ category }}. Avaliações geradas com Inteligência Artificial.{% endblock %}

{% block structured_data %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "{{ category }} — ReviewIA",
  "url": "{{ app.request.uri }}",
  "inLanguage": "pt-BR",
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": {{ products|length }},
    "itemListElement": [
      {% for product in products %}
      {
        "@type": "ListItem",
        "position": {{ loop.index }},
        "url": "{{ url('product_show', {slug: product.slug}) }}",
        "name": "{{ product.name|e('js') }}"
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    ]
  }
}
</script>
{% endblock %}

{% block stylesheets %}
<style>
/* ── Reveal animation ── */
.reveal {
  opacity: 0;
  transform: translateY(22px);
  transition: opacity .5s ease, transform .5s ease;
}
.reveal.visible { opacity:1; transform:none; }

/* ── Hero ── */
.hero {
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg,#0f0e17 0%,#1a1040 60%,#0d1b2a 100%);
  padding: 4rem 0 3rem;
  color: #fff;
}
.hero-glow {
  position: absolute;
  width: 600px; height: 600px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(124,58,237,.35) 0%, transparent 70%);
  top: -150px; right: -100px;
  pointer-events: none;
}
.hero-grid {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(255,255,255,.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,.03) 1px, transparent 1px);
  background-size: 40px 40px;
  pointer-events: none;
}
.hero-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: .4rem;
  background: rgba(124,58,237,.18);
  border: 1px solid rgba(124,58,237,.35);
  color: #c4b5fd;
  font-size: .75rem;
  font-weight: 700;
  font-family: 'DM Sans',sans-serif;
  letter-spacing: .08em;
  text-transform: uppercase;
  padding: .35rem .85rem;
  border-radius: 999px;
  margin-bottom: 1rem;
}
.hero-title {
  font-family: 'Playfair Display',serif;
  font-size: clamp(1.75rem,4vw,2.75rem);
  font-weight: 900;
  line-height: 1.15;
  color: #fff;
  margin-bottom: .75rem;
}
.hero-title .accent { color: #a78bfa; }
.hero-sub {
  font-family: 'DM Sans',sans-serif;
  font-size: .95rem;
  color: rgba(255,255,255,.65);
  max-width: 480px;
  line-height: 1.65;
}
.breadcrumb-bar {
  font-family: 'DM Sans',sans-serif;
  font-size: .78rem;
  color: rgba(255,255,255,.45);
  margin-bottom: .85rem;
}
.breadcrumb-bar a { color: rgba(255,255,255,.55); text-decoration: none; }
.breadcrumb-bar a:hover { color: #a78bfa; }
.breadcrumb-bar .sep { margin: 0 .4rem; }

/* ── Categories ── */
.cats-section {
  padding: 1.25rem 0;
  border-bottom: 1px solid #f3f4f6;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2px 8px rgba(0,0,0,.04);
}
.cat-chip {
  display: inline-flex;
  align-items: center;
  gap: .35rem;
  padding: .4rem .95rem;
  border-radius: 999px;
  font-size: .78rem;
  font-weight: 600;
  font-family: 'DM Sans',sans-serif;
  background: #f3f4f6;
  color: #374151;
  text-decoration: none;
  border: 1.5px solid transparent;
  transition: all .18s;
  white-space: nowrap;
}
.cat-chip:hover { background:#ede9fe; color:#4f46e5; }
.cat-chip.active { background:#4f46e5; color:#fff; border-color:#4f46e5; }
.cat-chip i { font-size:.65rem; }

/* ── Section ── */
.grid-section { padding: 2.5rem 0 4rem; }
.section-eyebrow {
  display: inline-flex; align-items:center; gap:.4rem;
  font-size:.72rem; font-weight:700; font-family:'DM Sans',sans-serif;
  color:#7c3aed; text-transform:uppercase; letter-spacing:.08em;
  margin-bottom:.5rem;
}
.section-title {
  font-family:'Playfair Display',serif;
  font-size:1.5rem; font-weight:900; color:#111827; margin-bottom:1.25rem;
}
.grid-header {
  display:flex; justify-content:space-between; align-items:flex-end;
  margin-bottom:1.5rem; flex-wrap:wrap; gap:1rem;
}

/* ── Product Card ── */
.pcard {
  display:flex; flex-direction:column;
  background:#fff;
  border-radius:16px;
  overflow:hidden;
  text-decoration:none;
  border:1px solid #f3f4f6;
  box-shadow:0 2px 12px rgba(0,0,0,.06);
  transition: transform .22s ease, box-shadow .22s ease;
  height:100%;
}
.pcard:hover { transform:translateY(-5px); box-shadow:0 10px 30px rgba(0,0,0,.12); }
.pcard-img {
  position:relative; overflow:hidden;
  height:200px; background:#f8f8f8;
}
.pcard-img img { width:100%; height:100%; object-fit:cover; transition:transform .4s ease; }
.pcard:hover .pcard-img img { transform:scale(1.05); }
.pcard-img-ph {
  width:100%; height:100%;
  display:flex; align-items:center; justify-content:center;
  background:linear-gradient(135deg,#f5f3ff,#ede9fe);
  color:#c4b5fd; font-size:2rem;
}
.pcard-overlay {
  position:absolute; inset:0;
  background:linear-gradient(180deg,transparent 40%,rgba(79,70,229,.7) 100%);
  display:flex; align-items:flex-end; justify-content:center;
  padding-bottom:1rem;
  opacity:0; transition:opacity .25s;
}
.pcard:hover .pcard-overlay { opacity:1; }
.pcard-overlay-cta {
  color:#fff; font-size:.78rem; font-weight:700;
  font-family:'DM Sans',sans-serif; display:flex; align-items:center; gap:.3rem;
}
.pcard-body { padding:1rem 1.1rem; flex:1; }
.pcard-cat {
  display:inline-block;
  background:#ede9fe; color:#6d28d9;
  font-size:.68rem; font-weight:700;
  font-family:'DM Sans',sans-serif;
  padding:.2em .65em; border-radius:999px;
  text-transform:uppercase; letter-spacing:.05em;
  margin-bottom:.5rem;
}
.pcard-name {
  font-family:'Playfair Display',serif;
  font-size:1rem; font-weight:700; color:#111827;
  line-height:1.3; margin-bottom:.5rem;
}
.pcard-verdict {
  font-size:.8rem; color:#6b7280;
  font-family:'DM Sans',sans-serif;
  line-height:1.55; margin-bottom:.65rem;
}
.pcard-pros { display:flex; flex-direction:column; gap:.25rem; }
.pcard-pro {
  display:flex; align-items:center; gap:.4rem;
  font-size:.75rem; color:#065f46;
  font-family:'DM Sans',sans-serif;
}
.pcard-pro::before { content:'✓'; color:#10b981; font-weight:800; }
.pcard-foot {
  display:flex; align-items:center; justify-content:space-between;
  padding:.75rem 1.1rem;
  border-top:1px solid #f3f4f6;
  background:#fafafa;
}
.pcard-price {
  font-family:'DM Sans',sans-serif;
  font-weight:700; color:#111827; font-size:.95rem;
}
.pcard-price small { font-size:.65rem; color:#9ca3af; font-weight:400; display:block; }
.pcard-arrow {
  width:30px; height:30px;
  background:#4f46e5; color:#fff;
  border-radius:50%; display:flex;
  align-items:center; justify-content:center;
  font-size:.75rem;
  transition:background .15s, transform .15s;
}
.pcard:hover .pcard-arrow { background:#3730a3; transform:scale(1.1); }

/* ── Pagination ── */
.pagination-wrap {
  display:flex; justify-content:center; gap:.5rem;
  margin-top:2.5rem; flex-wrap:wrap;
}
.page-btn {
  display:inline-flex; align-items:center; justify-content:center;
  width:38px; height:38px;
  border-radius:8px;
  font-family:'DM Sans',sans-serif; font-size:.85rem; font-weight:600;
  background:#f3f4f6; color:#374151;
  text-decoration:none;
  transition:all .18s;
}
.page-btn:hover { background:#ede9fe; color:#4f46e5; }
.page-btn.active { background:#4f46e5; color:#fff; }
.page-btn.disabled { opacity:.4; pointer-events:none; }

/* ── Empty state ── */
.empty-state {
  text-align:center;
  padding:4rem 1rem;
  color:#9ca3af;
}
.empty-state-icon {
  width:72px; height:72px;
  background:#f3f4f6; border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  font-size:2rem; color:#d1d5db;
  margin:0 auto 1.25rem;
}
.empty-state h2 {
  font-family:'Playfair Display',serif;
  font-size:1.3rem; color:#374151; margin-bottom:.5rem;
}
.empty-state p {
  font-family:'DM Sans',sans-serif;
  font-size:.875rem; max-width:36ch; margin:0 auto .75rem;
}
</style>
{% endblock %}

{% block body %}

{# ── Hero da categoria ── #}
<section class="hero" aria-label="Categoria {{ category }}">
    <div class="hero-grid"></div>
    <div class="hero-glow"></div>
    <div class="container">
        <nav class="breadcrumb-bar" aria-label="Navegação">
            <a href="{{ path('product_index') }}">Início</a>
            <span class="sep">›</span>
            {{ category }}
        </nav>
        <div class="hero-eyebrow"><i class="fas fa-tag"></i> Categoria</div>
        <h1 class="hero-title"><span class="accent">{{ category }}</span></h1>
        <p class="hero-sub">
            {{ total }} {{ total == 1 ? 'produto encontrado' : 'produtos encontrados' }} nesta categoria —
            avaliados com Inteligência Artificial.
        </p>
    </div>
</section>

{# ── Categories sticky ── #}
<section class="cats-section" aria-label="Categorias">
    <div class="container">
        <div class="d-flex gap-2 flex-wrap align-items-center">
            <span style="font-family:'DM Sans',sans-serif;font-size:.72rem;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.08em;margin-right:.25rem;white-space:nowrap;">
                Categorias:
            </span>
            <a class="cat-chip" href="{{ path('product_index') }}">
                <i class="fas fa-th"></i> Todos
            </a>
            {% for cat in categories %}
            <a class="cat-chip {{ cat == category ? 'active' : '' }}"
               href="{{ path('product_category', {category: cat}) }}">
                <i class="fas fa-tag"></i> {{ cat }}
            </a>
            {% endfor %}
        </div>
    </div>
</section>

{# ── Grid ── #}
<div class="container">
    <section class="grid-section">
        <div class="grid-header">
            <div>
                <div class="section-eyebrow"><i class="fas fa-th-large"></i> Resultados</div>
                <h2 class="section-title" style="margin-bottom:0">
                    {{ total }} {{ total == 1 ? 'produto em' : 'produtos em' }}
                    <span style="color:#7c3aed">{{ category }}</span>
                </h2>
            </div>
        </div>

        {% if products is empty %}
        <div class="empty-state reveal">
            <div class="empty-state-icon"><i class="fas fa-box-open"></i></div>
            <h2>Nenhum produto encontrado</h2>
            <p>Ainda não há produtos nesta categoria.</p>
            <a href="{{ path('product_index') }}"
               style="display:inline-flex;align-items:center;gap:.4rem;background:#4f46e5;color:#fff;font-family:'DM Sans',sans-serif;font-size:.85rem;font-weight:700;padding:.55rem 1.25rem;border-radius:8px;text-decoration:none;margin-top:.25rem;">
                <i class="fas fa-arrow-left"></i> Ver todos os produtos
            </a>
        </div>
        {% else %}
        <div class="row g-4" role="list">
            {% for product in products %}
            <div class="col-xl-3 col-lg-4 col-md-6 reveal" role="listitem">
                <a href="{{ url('product_show', {slug: product.slug}) }}" class="pcard" aria-label="{{ product.name }}">
                    <div class="pcard-img">
                        {% if product.imageUrl %}
                            <img src="{{ product.imageUrl }}" alt="Review de {{ product.name }}" loading="lazy">
                        {% else %}
                            <div class="pcard-img-ph"><i class="fas fa-box"></i></div>
                        {% endif %}
                        <div class="pcard-overlay">
                            <span class="pcard-overlay-cta"><i class="fas fa-book-open"></i> Ver review</span>
                        </div>
                    </div>
                    <div class="pcard-body">
                        {% if product.category %}<span class="pcard-cat">{{ product.category }}</span>{% endif %}
                        <h2 class="pcard-name">{{ product.name }}</h2>
                        <p class="pcard-verdict">{{ product.aiVerdict|striptags|slice(0, 110) }}{% if product.aiVerdict|length > 110 %}…{% endif %}</p>
                        {% if product.pros|length %}
                        <div class="pcard-pros">
                            {% for pro in product.pros|slice(0, 2) %}
                            <div class="pcard-pro">{{ pro }}</div>
                            {% endfor %}
                        </div>
                        {% endif %}
                    </div>
                    <div class="pcard-foot">
                        <div class="pcard-price">
                            <small>A partir de</small>
                            R$ {{ product.currentPrice|number_format(2, ',', '.') }}
                        </div>
                        <div class="pcard-arrow"><i class="fas fa-arrow-right"></i></div>
                    </div>
                </a>
            </div>
            {% endfor %}
        </div>

        {# ── Paginação ── #}
        {% if pages > 1 %}
        <nav class="pagination-wrap" aria-label="Paginação">
            <a href="{{ path('product_category', {category: category, page: page - 1}) }}"
               class="page-btn {{ page <= 1 ? 'disabled' : '' }}" aria-label="Anterior">
                <i class="fas fa-chevron-left"></i>
            </a>
            {% for p in 1..pages %}
            <a href="{{ path('product_category', {category: category, page: p}) }}"
               class="page-btn {{ p == page ? 'active' : '' }}">{{ p }}</a>
            {% endfor %}
            <a href="{{ path('product_category', {category: category, page: page + 1}) }}"
               class="page-btn {{ page >= pages ? 'disabled' : '' }}" aria-label="Próxima">
                <i class="fas fa-chevron-right"></i>
            </a>
        </nav>
        {% endif %}
        {% endif %}
    </section>
</div>

{% endblock %}

{% block javascripts %}
<script>
(function(){
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if(e.isIntersecting){
        e.target.classList.add('visible');
        obs.unobserve(e.target);
      }
    });
  }, {threshold: 0.12});
  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
})();
</script>
{% endblock %}
